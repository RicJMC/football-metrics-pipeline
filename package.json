{
  "name": "football-metrics-pipeline",
  "version": "1.0.0",
  "description": "fbref web scrap",
  "main": "index.js",
  "scripts": {
    "start": "nodemon -e index.js",
    "scrape:all": "echo \"Run scrapers manually from scrappe/ (legacy mode)\"",
    "etl": "node index.js",
    "etl:from-scripts-dir": "cd scripts && node index.js",
    "pipeline": "npm run etl",
    "pipeline:sample": "node scripts/pipeline-sample.js",
    "pipeline:sample:stage1": "node scripts/pipeline-sample.js --stage1",
    "inventory": "node -v && npm -v",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:characterization",
    "test:characterization": "node --test test/characterization/*.test.js",
    "verify": "node scripts/verify.js"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.4.0",
    "cheerio": "^1.0.0-rc.12",
    "csv-parse": "^5.5.5",
    "dotenv": "^8.2.0",
    "encoding-japanese": "^2.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "lodash": "^4.17.21",
    "nodemon": "^3.1.0",
    "objects-to-csv": "^1.3.6",
    "puppeteer": "^22.3.0",
    "simple-statistics": "^7.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.3"
  }
}
